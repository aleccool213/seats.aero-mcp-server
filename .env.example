# Copy this file to .env and fill in your values for local development.
# .env is gitignored — never commit real secrets.

# === Required ===
SEATS_API_KEY=your_seats_aero_partner_api_key_here

# === For running in HTTP mode locally (recommended for testing remote behavior) ===
MCP_TRANSPORT=http
MCP_AUTH_TOKEN=dev-secret-token-change-me
PORT=3000

# Optional: If you want to test with a specific Node env
# NODE_ENV=development
